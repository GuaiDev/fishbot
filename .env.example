# Anthropic API key — get one at https://console.anthropic.com/
# Note: Claude Code reuses your OAuth session for its own calls.
# But the SDK (used by this bot at runtime) needs its own key.
ANTHROPIC_API_KEY=your-key-here

# Model selection (default shown)
CLAUDE_MODEL=claude-sonnet-4-6

# Logging
LOG_LEVEL=INFO
